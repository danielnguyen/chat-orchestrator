# Docker Compose / container template.
# For local host-run, copy `api/.env.example` to `api/.env`.
ORCH_API_KEY=change_me

MEMORY_STORE_BASE_URL=http://basic-memory-store:8000
MEMORY_STORE_API_KEY=change_me

# Optional Cognitive Runtime integrations
COGNITIVE_RUNTIME_BASE_URL=
COGNITIVE_RUNTIME_API_KEY=
COGNITIVE_RUNTIME_TIMEOUT_MS=1500
COGNITIVE_RUNTIME_COMPANION_ENABLED=false
COGNITIVE_RUNTIME_INTERACTION_GOVERNANCE_ENABLED=false
COGNITIVE_RUNTIME_PERSONA_CONTAINMENT_ENABLED=false
COGNITIVE_RUNTIME_RESTRAINT_ENABLED=false

LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=

ROUTER_RULES_PATH=/app/api/router/rules.yaml
MODEL_REGISTRY_PATH=/app/api/router/model_registry.yaml

ALLOW_MANUAL_OVERRIDE=true
DEFAULT_PROFILE_NAME=dev
OFFLINE_PROVIDER=litellm-local
OLLAMA_BASE_URL=
REQUEST_TIMEOUT_MS=30000
